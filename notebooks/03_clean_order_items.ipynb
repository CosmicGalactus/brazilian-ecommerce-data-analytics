{\n "nbformat": 4,\n "nbformat_minor": 5,\n "metadata": {\n  "kernelspec": {"display_name": "Python 3", "language": "python", "name": "python3"},\n  "language_info": {"name": "python", "version": "3.10.0"}\n },\n "cells": [\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["# Notebook 03 — Clean Order Items Dataset\n", "**Table:** `olist_order_items_dataset.csv`\n", "\n", "## What this notebook does\n", "1. Load raw order items CSV\n", "2. Fix dtypes (datetime for shipping_limit_date)\n", "3. Validate price and freight values (remove negatives/zeros)\n", "4. Check order_item_id sequencing per order\n", "5. Verify referential integrity keys\n", "6. Derive item-level features\n", "7. Export cleaned file to `data/cleaned/order_items_cleaned.csv`"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["import pandas as pd\n", "import numpy as np\n", "import matplotlib.pyplot as plt\n", "import seaborn as sns\n", "import os\n", "\n", "pd.set_option('display.max_columns', None)\n", "sns.set_theme(style='whitegrid')\n", "print('Libraries loaded')"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 1. Load Raw Data"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["RAW_PATH = '../data/raw/olist_order_items_dataset.csv'\n", "CLEANED_PATH = '../data/cleaned/order_items_cleaned.csv'\n", "\n", "df = pd.read_csv(RAW_PATH)\n", "print(f'Shape: {df.shape}')\n", "df.head()"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 2. Basic Info and Missing Values"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["df.info()\n", "print('\\nMissing values:')\n", "print(df.isnull().sum())"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 3. Fix Data Types"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["df['order_id'] = df['order_id'].astype(str).str.strip()\n", "df['product_id'] = df['product_id'].astype(str).str.strip()\n", "df['seller_id'] = df['seller_id'].astype(str).str.strip()\n", "\n", "df['shipping_limit_date'] = pd.to_datetime(df['shipping_limit_date'], errors='coerce')\n", "\n", "df['price'] = pd.to_numeric(df['price'], errors='coerce')\n", "df['freight_value'] = pd.to_numeric(df['freight_value'], errors='coerce')\n", "\n", "print('Dtypes fixed.')\n", "print(df.dtypes)"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 4. Validate Price and Freight Values"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["print(f'Rows with price <= 0: {(df[\"price\"] <= 0).sum()}')\n", "print(f'Rows with freight_value < 0: {(df[\"freight_value\"] < 0).sum()}')\n", "print(f'Rows with null price: {df[\"price\"].isnull().sum()}')\n", "\n", "# Flag and remove rows with invalid price\n", "before = len(df)\n", "df = df[df['price'] > 0]\n", "df = df[df['freight_value'] >= 0]\n", "print(f'\\nRows removed due to invalid price/freight: {before - len(df)}')\n", "print(f'Shape after: {df.shape}')"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 5. Check order_item_id Sequencing"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["# Check that order_item_id starts at 1 and increments per order\n", "item_check = df.groupby('order_id')['order_item_id'].agg(list)\n", "non_sequential = item_check[item_check.apply(lambda x: sorted(x) != list(range(1, len(x)+1)))]\n", "print(f'Orders with non-sequential order_item_id: {len(non_sequential)}')"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 6. Derive Item-Level Features"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["df['item_total_value'] = df['price'] + df['freight_value']\n", "\n", "print('Order item summary stats:')\n", "df[['price', 'freight_value', 'item_total_value']].describe()"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 7. Visualizations"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n", "\n", "axes[0].hist(df['price'].clip(upper=500), bins=50, color='steelblue', edgecolor='black')\n", "axes[0].set_title('Price Distribution (clipped at 500)')\n", "axes[0].set_xlabel('Price (BRL)')\n", "axes[0].set_ylabel('Count')\n", "\n", "axes[1].hist(df['freight_value'].clip(upper=100), bins=50, color='darkorange', edgecolor='black')\n", "axes[1].set_title('Freight Value Distribution (clipped at 100)')\n", "axes[1].set_xlabel('Freight Value (BRL)')\n", "axes[1].set_ylabel('Count')\n", "\n", "plt.tight_layout()\n", "plt.show()"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 8. Export Cleaned Data"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["os.makedirs('../data/cleaned', exist_ok=True)\n", "df.to_csv(CLEANED_PATH, index=False)\n", "print(f'Saved to: {CLEANED_PATH}')\n", "print(f'Final shape: {df.shape}')"]\n  }\n ]\n}
