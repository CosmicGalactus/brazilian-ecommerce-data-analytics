{\n "nbformat": 4,\n "nbformat_minor": 5,\n "metadata": {\n  "kernelspec": {"display_name": "Python 3", "language": "python", "name": "python3"},\n  "language_info": {"name": "python", "version": "3.10.0"}\n },\n "cells": [\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["# Notebook 04 — Clean Payments Dataset\n", "**Table:** `olist_order_payments_dataset.csv`\n", "\n", "## What this notebook does\n", "1. Load raw payments CSV\n", "2. Fix dtypes and standardize payment_type\n", "3. Validate installments and payment values\n", "4. Aggregate payments per order\n", "5. Visualize payment methods\n", "6. Export cleaned file to `data/cleaned/payments_cleaned.csv`"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["import pandas as pd\n", "import numpy as np\n", "import matplotlib.pyplot as plt\n", "import seaborn as sns\n", "import os\n", "\n", "pd.set_option('display.max_columns', None)\n", "sns.set_theme(style='whitegrid')\n", "print('Libraries loaded')"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 1. Load Raw Data"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["RAW_PATH = '../data/raw/olist_order_payments_dataset.csv'\n", "CLEANED_PATH = '../data/cleaned/payments_cleaned.csv'\n", "\n", "df = pd.read_csv(RAW_PATH)\n", "print(f'Shape: {df.shape}')\n", "df.head()"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 2. Basic Info"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["df.info()\n", "print('\\nMissing values:')\n", "print(df.isnull().sum())"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 3. Fix Data Types and Normalize payment_type"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["df['order_id'] = df['order_id'].astype(str).str.strip()\n", "df['payment_type'] = df['payment_type'].str.lower().str.strip()\n", "df['payment_installments'] = pd.to_numeric(df['payment_installments'], errors='coerce').astype('Int64')\n", "df['payment_value'] = pd.to_numeric(df['payment_value'], errors='coerce')\n", "df['payment_sequential'] = pd.to_numeric(df['payment_sequential'], errors='coerce').astype('Int64')\n", "\n", "print('Unique payment types:', df['payment_type'].unique())"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 4. Validate Installments and Values"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["print(f'Rows with payment_installments == 0: {(df[\"payment_installments\"] == 0).sum()}')\n", "print(f'Rows with payment_value <= 0: {(df[\"payment_value\"] <= 0).sum()}')\n", "print(f'Max installments: {df[\"payment_installments\"].max()}')\n", "\n", "# Flag suspicious installments\n", "df['flag_high_installments'] = (df['payment_installments'] > 24).astype(int)\n", "print(f'\\nOrders with >24 installments: {df[\"flag_high_installments\"].sum()}')"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 5. Aggregate Payments per Order"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["payments_agg = df.groupby('order_id').agg(\n", "    total_payment_value=('payment_value', 'sum'),\n", "    num_payment_attempts=('payment_sequential', 'max'),\n", "    payment_types=('payment_type', lambda x: list(x.unique())),\n", "    max_installments=('payment_installments', 'max')\n", ").reset_index()\n", "\n", "print(f'Aggregated payment table shape: {payments_agg.shape}')\n", "payments_agg.head()"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 6. Visualizations"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n", "\n", "df['payment_type'].value_counts().plot(kind='bar', ax=axes[0], color='mediumseagreen', edgecolor='black')\n", "axes[0].set_title('Payment Type Distribution')\n", "axes[0].set_xlabel('Payment Type')\n", "axes[0].set_ylabel('Count')\n", "axes[0].tick_params(axis='x', rotation=30)\n", "\n", "df['payment_installments'].value_counts().sort_index().plot(kind='bar', ax=axes[1], color='mediumpurple', edgecolor='black')\n", "axes[1].set_title('Payment Installments Distribution')\n", "axes[1].set_xlabel('Installments')\n", "axes[1].set_ylabel('Count')\n", "\n", "plt.tight_layout()\n", "plt.show()"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 7. Export Cleaned Data"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["os.makedirs('../data/cleaned', exist_ok=True)\n", "df.to_csv(CLEANED_PATH, index=False)\n", "print(f'Saved to: {CLEANED_PATH}')\n", "print(f'Final shape: {df.shape}')"]\n  }\n ]\n}
