{\n "nbformat": 4,\n "nbformat_minor": 5,\n "metadata": {\n  "kernelspec": {"display_name": "Python 3", "language": "python", "name": "python3"},\n  "language_info": {"name": "python", "version": "3.10.0"}\n },\n "cells": [\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["# Notebook 02 — Clean Customers Dataset\n", "**Table:** `olist_customers_dataset.csv`\n", "\n", "## What this notebook does\n", "1. Load raw customers CSV\n", "2. Fix dtypes (zip as string)\n", "3. Standardize city and state fields\n", "4. Check for duplicates on customer_id\n", "5. Analyze customer_unique_id (repeat customers)\n", "6. Export cleaned file to `data/cleaned/customers_cleaned.csv`"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["import pandas as pd\n", "import numpy as np\n", "import matplotlib.pyplot as plt\n", "import seaborn as sns\n", "import os\n", "\n", "pd.set_option('display.max_columns', None)\n", "sns.set_theme(style='whitegrid')\n", "print('Libraries loaded')"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 1. Load Raw Data"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["RAW_PATH = '../data/raw/olist_customers_dataset.csv'\n", "CLEANED_PATH = '../data/cleaned/customers_cleaned.csv'\n", "\n", "df = pd.read_csv(RAW_PATH)\n", "print(f'Shape: {df.shape}')\n", "df.head()"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 2. Basic Info and Missing Values"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["df.info()\n", "print('\\nMissing values:')\n", "print(df.isnull().sum())"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 3. Fix Data Types"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["# IDs to string\n", "df['customer_id'] = df['customer_id'].astype(str).str.strip()\n", "df['customer_unique_id'] = df['customer_unique_id'].astype(str).str.strip()\n", "\n", "# Zip code as zero-padded 5-char string\n", "df['customer_zip_code_prefix'] = df['customer_zip_code_prefix'].astype(str).str.zfill(5)\n", "\n", "print('Dtypes fixed.')\n", "print(df.dtypes)"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 4. Standardize City and State"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["# Title case city, uppercase state\n", "df['customer_city'] = df['customer_city'].str.strip().str.title()\n", "df['customer_state'] = df['customer_state'].str.strip().str.upper()\n", "\n", "# Valid Brazilian states (27 UF codes)\n", "VALID_STATES = [\n", "    'AC','AL','AP','AM','BA','CE','DF','ES','GO','MA','MT','MS',\n", "    'MG','PA','PB','PR','PE','PI','RJ','RN','RS','RO','RR','SC',\n", "    'SP','SE','TO'\n", "]\n", "\n", "invalid_states = df[~df['customer_state'].isin(VALID_STATES)]\n", "print(f'Rows with invalid state codes: {len(invalid_states)}')\n", "if len(invalid_states) > 0:\n", "    print(invalid_states['customer_state'].value_counts())"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 5. Check Duplicate customer_ids"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["dups = df['customer_id'].duplicated().sum()\n", "print(f'Duplicate customer_ids: {dups}')\n", "if dups > 0:\n", "    df = df.drop_duplicates(subset='customer_id', keep='first')\n", "    print(f'Shape after dedup: {df.shape}')"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 6. Analyze Repeat Customers (customer_unique_id)"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["orders_per_customer = df.groupby('customer_unique_id').size().reset_index(name='order_count')\n", "repeat = orders_per_customer[orders_per_customer['order_count'] > 1]\n", "print(f'Total unique customers: {len(orders_per_customer)}')\n", "print(f'Repeat customers (>1 order): {len(repeat)}')\n", "print(f'Repeat customer rate: {len(repeat)/len(orders_per_customer)*100:.2f}%')\n", "orders_per_customer['order_count'].value_counts().head(10)"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 7. State Distribution Visualization"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["fig, axes = plt.subplots(1, 2, figsize=(16, 5))\n", "\n", "df['customer_state'].value_counts().plot(kind='bar', ax=axes[0], color='teal', edgecolor='black')\n", "axes[0].set_title('Customers by State')\n", "axes[0].set_xlabel('State')\n", "axes[0].set_ylabel('Count')\n", "axes[0].tick_params(axis='x', rotation=45)\n", "\n", "top_cities = df['customer_city'].value_counts().head(15)\n", "top_cities.plot(kind='barh', ax=axes[1], color='steelblue', edgecolor='black')\n", "axes[1].set_title('Top 15 Customer Cities')\n", "axes[1].set_xlabel('Count')\n", "axes[1].invert_yaxis()\n", "\n", "plt.tight_layout()\n", "plt.show()"]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": ["## 8. Export Cleaned Data"]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": ["os.makedirs('../data/cleaned', exist_ok=True)\n", "df.to_csv(CLEANED_PATH, index=False)\n", "print(f'Saved to: {CLEANED_PATH}')\n", "print(f'Final shape: {df.shape}')"]\n  }\n ]\n}
